# ============================================================
# Fall Detection Web — Environment Variables
# ============================================================
# Cấu hình chính được lưu trong Postgres (qua db.py).
# Các biến dưới đây dùng để OVERRIDE giá trị trong DB,
# phù hợp cho container / Home Assistant Addon.
# ============================================================

# DB (Phase 0 — Postgres). Ưu tiên DATABASE_URL; hoặc set DB_* rời.
DATABASE_URL=postgresql://dcnet:dcnet_dev@localhost:5432/dcnet
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=dcnet
# DB_PASSWORD=dcnet_dev
# DB_NAME=dcnet

# RTSP stream URL (fallback nếu chưa cấu hình camera trong UI)
# RTSP_URL=rtsp://10.10.0.2:8554/bep_sub

# go2rtc public URL
# GO2RTC_URL=http://10.10.0.2:1984

# Telegram
# TELEGRAM_BOT_TOKEN=123456789:AABBCCxx
# TELEGRAM_CHAT_ID=-100123456789

# AI API
# AI_BASE_URL=https://9router.minhhungtsbd.me/v1
# AI_API_KEY=sk-xxxxx
# VISION_MODEL=gh/oswe-vscode-prime

# YOLO
# YOLO_MODEL=yolov8n.pt
# YOLO_IMGSZ=416
# CONFIDENCE=0.5
# FRAME_SKIP=2
# LOOP_SLEEP=0.3

# Cooldowns
# VERIFY_INTERVAL=20
# ALERT_COOLDOWN=300

# Webhook token (bảo vệ endpoint nếu có)
# WEBHOOK_TOKEN=my-secret-token
